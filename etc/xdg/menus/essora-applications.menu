                <And><Category>X-FilesystemFind</Category></And>
				<And><Category>X-Filesystem-mount</Category></And>
				<And><Category>X-Filesystem-storage</Category></And>
				<And><Category>Archiving</Category></And>	
		        <And><Category>TerminalEmulator</Category></And>
