				<And><Category>Translation</Category></And>
				<And><Category>GUIDesigner</Category></And>
				<And><Category>X-Develop-Sub</Category></And>    
			    <And><Category>Utility</Category></And>
				<And><Category>TerminalEmulator</Category></And>
				<And><Category>Shell</Category></And>
				<And><Category>Utility</Category></And>
				<And><Category>X-Utility</Category></And>
				<And><Category>X-Utility-development</Category></And>
				<And><Category>Emulator</Category></And>
				<And><Category>Documentation</Category></And>
