				<And><Category>GUIDesigner</Category></And>
				<And><Category>X-Develop-Sub</Category></And>
				<And><Category>Accessibility</Category></And>			
		</Include>
	</Menu> <!-- End Accessories -->

	<!-- Accessibility submenu -->
	<Menu>
		<Name>Universal Access</Name>
		<Directory>essora-utilities.directory</Directory>
