<!DOCTYPE Menu PUBLIC "-//freedesktop//DTD Menu 1.0//EN"
 "http://www.freedesktop.org/standards/menu-spec/1.0/menu.dtd">

<Menu>

	<Name>Applications</Name>
	<Directory>essora-menu-applications.directory</Directory>

	<!-- Read standard .directory and .desktop file locations -->
	<DefaultAppDirs/>
	<DefaultDirectoryDirs/>

	<!-- Read in overrides and child menus from applications-merged/ -->
	<DefaultMergeDirs/>
		<Menu>
		<Name>Favorites</Name>
		<Directory>essora-favorites.directory</Directory>
		<Include>
			<And>
				<Category>Favorites</Category>  <!-- Si existe la categoría 'Favorites' en .desktop -->
			</And>
		</Include>
	</Menu> <!-- Fin Favoritos -->
	<!-- Accessories submenu -->
	<Menu>
		<Name>Accessories</Name>
            <Directory>essora-utilities.directory</Directory>
			<Include>
