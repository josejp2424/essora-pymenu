	<!-- Other -->
	<Menu>
		<Name>Other</Name>
		<Directory>essora-other.directory</Directory>
		<OnlyUnallocated/>
		<Include>
				<And><Category>X-LXDE-Settings</Category></And>
			    
		</Include>
		</Menu> <!-- End Other -->

	<Menu>
		<Name>DesktopSettings</Name>
		<Directory>essora-desktop.directory</Directory>
		<OnlyUnallocated/>
		<Include>
				<And><Category>Settings</Category></And>
				<And><Category>X-Desktop</Category></And>
                <And><Category>X-Desktop-appearance</Category></And>
                <And><Category>DesktopSettings</Category></And>
                <And><Category>X-Desktop-settings</Category></And>
                <And><Category>X-DesktopCountry</Category></And>
                <And><Category>Accessibility</Category></And>
                <And><Category>X-Desktop-windows</Category></And>
                <And><Category>X-Desktop-sleep</Category></And>
                <And><Category>Screensaver</Category></And>
                <And><Category>X-Desktop-applet</Category></And>
                <And><Category>X-DesktopApplets</Category></And>
                <And><Category>Clock</Category></And>
				<And><Category>PackageManager</Category></And>
				<And><Category>System</Category></And>
		</Include>
		<Layout>
			<Merge type="menus"/>
			<Merge type="files"/>
		</Layout>

	</Menu> <!-- End Settings -->

	<Layout>
		<Merge type="files"/>
		<Merge type="menus"/>
		<Separator/>
		<Menuname>DesktopSettings</Menuname>
	</Layout>

</Menu> <!-- End Applications -->
